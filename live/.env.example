# Mangoma Live Streaming - Environment Configuration

# Google Gemini API Key (required)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-api-key-here

# Lyria Model (experimental, free tier)
LYRIA_MODEL=lyria-realtime-exp

# Server Configuration
PORT=8080
HOST=localhost

# YouTube Streaming (required for actual streaming)
# Get from: YouTube Studio → Create → Go Live → Stream
YOUTUBE_STREAM_KEY=
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2

# Audio Configuration
AUDIO_SAMPLE_RATE=48000
AUDIO_CHANNELS=2
AUDIO_BITRATE=192k

# Logging
LOG_LEVEL=info

# Preset Directory
PRESETS_DIR=./presets
